<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="stereo_cameras">

  <!-- Two cameras 23 inches = 0.5842 m apart center-to-center -->
  <xacro:property name="camera_separation" value="0.5842"/>   <!-- 23 inches -->
  <xacro:property name="camera_half_sep"   value="${camera_separation / 2}"/>


  <!-- Left camera -->
  <joint name="left_camera_joint" type="fixed">
    <parent link="body_link"/>
    <child link="left_camera_link"/>
    <origin xyz="${cam_x} ${ camera_half_sep} ${cam_z}" rpy="0 0 0"/>
  </joint>

  <link name="left_camera_link">
    <inertial>
      <mass value="${cam_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_length} ${cam_width} ${cam_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_length} ${cam_width} ${cam_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- Right camera -->
  <joint name="right_camera_joint" type="fixed">
    <parent link="body_link"/>
    <child link="right_camera_link"/>
    <origin xyz="${cam_x} ${-camera_half_sep} ${cam_z}" rpy="0 0 0"/>
  </joint>

  <link name="right_camera_link">
    <inertial>
      <mass value="${cam_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_length} ${cam_width} ${cam_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_length} ${cam_width} ${cam_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- Nice dark-grey material for both cameras -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

<gazebo reference="left_camera_link">
    <sensor type="camera" name="left_camera">
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov> <!-- 80 deg -->
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/left</namespace>
          <remapping>image_raw:=image_raw</remapping>
          <remapping>camera_info:=camera_info</remapping>
        </ros>
        <frame_name>left_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  
  <gazebo reference="right_camera_link">
    <sensor type="camera" name="right_camera">
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov> <!-- 80 deg -->
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/right</namespace>
          <remapping>image_raw:=image_raw</remapping>
          <remapping>camera_info:=camera_info</remapping>
        </ros>
        <frame_name>right_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  
</robot>
