<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="straight_lane_obstacles2">

    <plugin name='ignition::gazebo::systems::Physics' filename='ignition-gazebo-physics-system'/>
    <plugin name='ignition::gazebo::systems::UserCommands' filename='ignition-gazebo-user-commands-system'/>
    <plugin name='ignition::gazebo::systems::SceneBroadcaster' filename='ignition-gazebo-scene-broadcaster-system'/>
    <plugin name="ignition::gazebo::systems::Contact" filename="libignition-gazebo-contact-system.so">
    </plugin>
    
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.1 0.1 0.1 0.1</ambient>
      <background>0.8 0.8 0.8 1.0</background>
      <grid>true</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Course (centered) and bounding tiles so no cliffs-->
    <include> <uri>model://floor</uri> <pose>0 0 0 0 0 0</pose> </include>
    <include> <uri>model://floor_boundary</uri> <name>n</name> <pose>10 0 0 0 0 0</pose>  </include>
    <include> <uri>model://floor_boundary</uri> <name>s</name> <pose>-10 0 0 0 0 0</pose>  </include>
    <include> <uri>model://floor_boundary</uri> <name>e</name> <pose>0 10 0 0 0 0</pose> </include>
    <include> <uri>model://floor_boundary</uri> <name>w</name> <pose>0 -10 0 0 0 0</pose> </include>
    <include> <uri>model://floor_boundary</uri> <name>ne</name> <pose>10 10 0 0 0 0</pose> </include>
    <include> <uri>model://floor_boundary</uri> <name>nw</name> <pose>10 -10 0 0 0 0</pose> </include>
    <include> <uri>model://floor_boundary</uri> <name>se</name> <pose>-10 10 0 0 0 0</pose> </include>
    <include> <uri>model://floor_boundary</uri> <name>sw</name> <pose>-10 -10 0 0 0 0</pose> </include>
    
    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose>-1.8 14.4 8.6 0.0 0.545 -1.65</pose>
        <view_controller>orbit</view_controller>
      </camera>
    </gui>

    <!-- Obstacles -->
    <include>
      <uri>model://barrel</uri>
      <name>barrel_1</name>
      <pose>1.5 0.6 0.1 0 0 0</pose>
    </include>

    <include>
      <uri>model://barrel</uri>
      <name>barrel_2</name>
      <pose>-0.3 0.6 0.1 0 0 0</pose>
    </include>

    <!-- White lane boundaries-->
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary</name>
      <pose>-0.612888 4.40625 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_0</name>
      <pose>-0.661753 2.32727 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_1</name>
      <pose>-0.607988 3.35873 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_2</name>
      <pose>-0.643307 1.24872 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_3</name>
      <pose>-0.625472 0.182335 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_4</name>
      <pose>-0.672691 -0.838452 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_5</name>
      <pose>-0.662934 -1.93739 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_6</name>
      <pose>-0.657208 -2.98611 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_7</name>
      <pose>-0.653258 -4.06003 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_8</name>
      <pose>1.9704 -4.19173 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_9</name>
      <pose>1.9552 -3.0839 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_10</name>
      <pose>1.97717 -1.95011 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_11</name>
      <pose>1.9512 -0.880665 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_12</name>
      <pose>1.95933 0.174807 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_13</name>
      <pose>1.96045 1.26046 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_14</name>
      <pose>1.95145 2.35338 0 0 0 -1.58307</pose>
    </include>
    <include>
      <uri>model://line_boundary</uri>
      <name>line_boundary_15</name>
      <pose>1.96928 3.50928 0 0 0 -1.58307</pose>
    </include>
